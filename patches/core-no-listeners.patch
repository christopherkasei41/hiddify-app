+
+func logInboundSummary(options *option.Options) {
+	if options == nil {
+		Log(LogLevel_WARNING, LogType_CORE, "[diag] InboundSummary: options is nil")
+		return
+	}
+	Log(LogLevel_INFO, LogType_CORE, fmt.Sprintf("[diag] InboundSummary: count=%d", len(options.Inbounds)))
+	for i, inb := range options.Inbounds {
+		listen := ""
+		listenPort := float64(0)
+		payload, err := json.Marshal(inb)
+		if err == nil {
+			var m map[string]interface{}
+			if json.Unmarshal(payload, &m) == nil {
+				if opts, ok := m["options"].(map[string]interface{}); ok {
+					if v, ok := opts["listen"].(string); ok {
+						listen = v
+					}
+					if v, ok := opts["listen_port"].(float64); ok {
+						listenPort = v
+					}
+					if lo, ok := opts["listen_options"].(map[string]interface{}); ok {
+						if v, ok := lo["listen"].(string); ok {
+							listen = v
+						}
+						if v, ok := lo["listen_port"].(float64); ok {
+							listenPort = v
+						}
+					}
+				}
+			}
+		}
+		Log(LogLevel_INFO, LogType_CORE, fmt.Sprintf("[diag] Inbound[%d]: type=%s tag=%s listen=%s listen_port=%d", i, inb.Type, inb.Tag, listen, int(listenPort)))
+	}
+	if options.Experimental != nil && options.Experimental.ClashAPI != nil {
+		Log(LogLevel_INFO, LogType_CORE, fmt.Sprintf("[diag] Experimental: clash_external_controller=%s", options.Experimental.ClashAPI.ExternalController))
+	}
+}
